@inject NavigationManager Navigation

@*
    Componente sem interface: redireciona o usuário não autenticado para a página de login.
    Usado no <NotAuthorized> do <AuthorizeRouteView> (App.razor) quando uma página com [Authorize] é acessada deslogado.
*@

@code {
    /// <summary>Ao inicializar, redireciona imediatamente para a página de login.</summary>
    ///
    /// <remarks>
    ///
    /// === <b>Restrições</b> ===
    ///
    /// <para>
    /// Não força recarregamento (navegação do lado do cliente), preservando o app WASM já carregado.
    /// </para>
    ///
    /// </remarks>
    protected override void OnInitialized()
    {
        this.Navigation.NavigateTo("login");
    }
}
