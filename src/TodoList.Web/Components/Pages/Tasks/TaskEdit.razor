@page "/tarefas/{Id:guid}/editar"
@attribute [Authorize]
@using System.Security.Claims
@inject TaskApiClient TaskApi
@inject NavigationManager Navigation

@*
    Página de edição de uma tarefa existente. 

    Carrega a tarefa pela API, preenche o formulário e envia um PUT. 

    Os campos são os mesmos do cadastro, acrescidos do estado de conclusão. 

    O responsável só é editável pelo admin; 
    para os demais (responsável editando a própria tarefa) ele é exibido como somente leitura, 
    pois o servidor não permite reatribuir.
*@

<PageTitle>Editar Tarefa</PageTitle>

<h1 class="h3 mb-3">Editar Tarefa</h1>

@if (_isLoading)
{
    <p class="text-muted">Carregando tarefa...</p>
}
else if (_notFound)
{
    <div class="alert alert-warning" role="alert">Tarefa não encontrada.</div>
    <a class="btn btn-secondary" href="tarefas">Voltar</a>
}
else
{
    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    }

    <EditForm Model="_model" OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label" for="title">Título</label>
            <InputText id="title" class="form-control" @bind-Value="_model.Title" />
            <ValidationMessage For="() => _model.Title" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="description">Descrição</label>
            <InputTextArea id="description" class="form-control" rows="4" @bind-Value="_model.Description" />
            <ValidationMessage For="() => _model.Description" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="dueDate">Data de entrega</label>
            <InputDate id="dueDate" class="form-control" @bind-Value="_model.DueDate" />
            <ValidationMessage For="() => _model.DueDate" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="difficulty">Dificuldade</label>
            <InputSelect id="difficulty" class="form-select" @bind-Value="_model.Difficulty">
                @foreach (Difficulty difficulty in Enum.GetValues<Difficulty>())
                {
                    <option value="@difficulty">@DifficultyDisplay.GetLabel(difficulty)</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label" for="responsible">Responsável</label>
            @if (_isAdmin)
            {
                <InputSelect id="responsible" class="form-select" @bind-Value="_model.ResponsibleUserId">
                    <option value="">Não atribuído</option>
                    @foreach (UserSummaryDto user in _selectableUsers)
                    {
                        <option value="@user.Id">@user.UserName</option>
                    }
                </InputSelect>
            }
            else
            {
                <input id="responsible" class="form-control" disabled
                       value="@(string.IsNullOrWhiteSpace(_responsibleUserName) ? "Não atribuído" : _responsibleUserName)" />
            }
        </div>

        <div class="form-check mb-3">
            <InputCheckbox id="isCompleted" class="form-check-input" @bind-Value="_model.IsCompleted" />
            <label class="form-check-label" for="isCompleted">Concluída</label>
        </div>

        <button type="submit" class="btn btn-primary" disabled="@_isSaving">Salvar</button>
        <a class="btn btn-secondary" href="tarefas">Cancelar</a>
    </EditForm>
}

@code {
    /// <summary>Estado de autenticação atual, fornecido pelo <CascadingAuthenticationState> (App.razor).</summary>
    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    /// <summary>Identificador da tarefa em edição, vindo da rota.</summary>
    [Parameter]
    public Guid Id { get; set; }

    /// <summary>Modelo vinculado ao formulário de edição.</summary>
    private UpdateTaskRequest _model = new();

    /// <summary>Indica se o usuário autenticado é admin (pode reatribuir o responsável).</summary>
    private bool _isAdmin;

    /// <summary>Usuários selecionáveis como responsável (carregados apenas para o admin).</summary>
    private IReadOnlyList<UserSummaryDto> _selectableUsers = Array.Empty<UserSummaryDto>();

    /// <summary>Nome do responsável atual, exibido como somente leitura para não-admins.</summary>
    private string? _responsibleUserName;

    /// <summary>Indica que a tarefa ainda está sendo carregada da API.</summary>
    private bool _isLoading = true;

    /// <summary>Indica que a tarefa solicitada não existe (resposta 404).</summary>
    private bool _notFound;

    /// <summary>Indica que a edição está em andamento (evita envios duplicados).</summary>
    private bool _isSaving;

    /// <summary>Mensagem de erro retornada pela API; nula quando não há erro.</summary>
    private string? _errorMessage;

    /// <summary>
    ///
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Resolve o papel do usuário (admin define se o responsável é editável).
    /// </para>
    ///
    /// <para>
    /// Carrega a tarefa pelo identificador da rota e preenche o modelo, ou sinaliza ausência (404).
    /// </para>
    ///
    /// <para>
    /// Para o admin, carrega a lista de usuários do seletor de responsável.
    /// </para>
    ///
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await this.AuthenticationStateTask;
        this._isAdmin = authState.User.IsInRole(AppRoles.Admin);

        try
        {
            TaskDto? task = await this.TaskApi.GetByIdAsync(this.Id);

            if (task is null)
            {
                this._notFound = true;
                return;
            }

            this._responsibleUserName = task.ResponsibleUserName;

            this._model = new UpdateTaskRequest
            {
                Title = task.Title,
                Description = task.Description,
                DueDate = task.DueDate,
                Difficulty = task.Difficulty,
                ResponsibleUserId = task.ResponsibleUserId,
                IsCompleted = task.IsCompleted
            };

            if (this._isAdmin)
            {
                this._selectableUsers = await this.TaskApi.GetUsersAsync();
            }
        }
        catch (HttpRequestException exception)
        {
            this._errorMessage = $"Não foi possível carregar a tarefa: {exception.Message}";
        }
        finally
        {
            this._isLoading = false;
        }
    }

    /// <summary>
    ///
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Envia o modelo para a API atualizar a tarefa.
    /// </para>
    ///
    /// <para>
    /// Em sucesso, navega para a lista; em erro de validação do servidor, exibe a mensagem.
    /// </para>
    ///
    /// </summary>
    private async Task SubmitAsync()
    {
        this._isSaving = true;
        this._errorMessage = null;

        try
        {
            this._errorMessage = await this.TaskApi.UpdateAsync(this.Id, this._model);

            if (this._errorMessage is null)
            {
                this.Navigation.NavigateTo("tarefas");
            }
        }
        catch (HttpRequestException exception)
        {
            this._errorMessage = $"Não foi possível salvar a tarefa: {exception.Message}";
        }
        finally
        {
            this._isSaving = false;
        }
    }
}
