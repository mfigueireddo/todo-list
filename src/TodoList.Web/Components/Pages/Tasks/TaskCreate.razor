@page "/tarefas/nova"
@attribute [Authorize]
@using System.Security.Claims
@inject TaskApiClient TaskApi
@inject NavigationManager Navigation

@*
    Página de cadastro de uma nova tarefa. 
    Formulário com título, descrição, data de entrega, dificuldade e responsável. 
    O seletor de responsável oferece todos os usuários para o admin 
    e apenas o próprio usuário (ou "Não atribuído") para um usuário comum.
*@

<PageTitle>Adicionar Nova Tarefa</PageTitle>

<h1 class="h3 mb-3">Adicionar Nova Tarefa</h1>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

<EditForm Model="_model" OnValidSubmit="SubmitAsync">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label" for="title">Título</label>
        <InputText id="title" class="form-control" @bind-Value="_model.Title" />
        <ValidationMessage For="() => _model.Title" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="description">Descrição</label>
        <InputTextArea id="description" class="form-control" rows="4" @bind-Value="_model.Description" />
        <ValidationMessage For="() => _model.Description" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="dueDate">Data de entrega</label>
        <InputDate id="dueDate" class="form-control" @bind-Value="_model.DueDate" />
        <ValidationMessage For="() => _model.DueDate" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="difficulty">Dificuldade</label>
        <InputSelect id="difficulty" class="form-select" @bind-Value="_model.Difficulty">
            @foreach (Difficulty difficulty in Enum.GetValues<Difficulty>())
            {
                <option value="@difficulty">@DifficultyDisplay.GetLabel(difficulty)</option>
            }
        </InputSelect>
    </div>

    <div class="mb-3">
        <label class="form-label" for="responsible">Responsável</label>
        <InputSelect id="responsible" class="form-select" @bind-Value="_model.ResponsibleUserId">
            <option value="">Não atribuído</option>
            @foreach (UserSummaryDto user in _selectableUsers)
            {
                <option value="@user.Id">@user.UserName</option>
            }
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-primary" disabled="@_isSaving">Salvar</button>
    <a class="btn btn-secondary" href="tarefas">Cancelar</a>
</EditForm>

@code {
    /// <summary>Estado de autenticação atual.</summary>
    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    /// <summary>Modelo vinculado ao formulário de criação. Inicia com data de entrega = hoje (data válida por padrão).</summary>
    private CreateTaskRequest _model = new()
    {
        DueDate = DateOnly.FromDateTime(DateTime.Today)
    };

    /// <summary>Usuários que podem ser escolhidos como responsável (todos para admin; só o próprio usuário para os demais).</summary>
    private IReadOnlyList<UserSummaryDto> _selectableUsers = Array.Empty<UserSummaryDto>();

    /// <summary>Indica que a criação está em andamento (evita envios duplicados).</summary>
    private bool _isSaving;

    /// <summary>Mensagem de erro retornada pela API (ex.: data inválida); nula quando não há erro.</summary>
    private string? _errorMessage;

    /// <summary>
    ///
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Resolve a identidade do usuário (id e papel).
    /// </para>
    ///
    /// <para>
    /// Carrega os usuários e restringe as opções de responsável conforme o papel (admin vê todos; comum, apenas a si mesmo).
    /// </para>
    ///
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await this.AuthenticationStateTask;
        ClaimsPrincipal user = authState.User;

        bool isAdmin = user.IsInRole(AppRoles.Admin);
        string? subject = user.FindFirst(JwtClaimNames.Subject)?.Value;
        Guid? currentUserId = Guid.TryParse(subject, out Guid userId) ? userId : null;

        try
        {
            IReadOnlyList<UserSummaryDto> users = await this.TaskApi.GetUsersAsync();
            this._selectableUsers = isAdmin
                ? users
                : users.Where(candidate => candidate.Id == currentUserId).ToList();
        }
        catch (HttpRequestException exception)
        {
            this._errorMessage = $"Não foi possível carregar a lista de usuários: {exception.Message}";
        }
    }

    /// <summary>
    ///
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Envia o modelo para a API criar a tarefa.
    /// </para>
    ///
    /// <para>
    /// Em sucesso, navega para a lista; 
    /// em erro de validação do servidor, exibe a mensagem.
    /// </para>
    ///
    /// </summary>
    ///
    /// <remarks>
    ///
    /// === <b>Restrições</b> ===
    ///
    /// <para>
    /// As validações de obrigatoriedade/tamanho são checadas no cliente e no servidor; a regra de data não-passada é validada no servidor.
    /// </para>
    ///
    /// </remarks>
    private async Task SubmitAsync()
    {
        this._isSaving = true;
        this._errorMessage = null;

        try
        {
            this._errorMessage = await this.TaskApi.CreateAsync(this._model);

            if (this._errorMessage is null)
            {
                this.Navigation.NavigateTo("tarefas");
            }
        }
        catch (HttpRequestException exception)
        {
            this._errorMessage = $"Não foi possível salvar a tarefa: {exception.Message}";
        }
        finally
        {
            this._isSaving = false;
        }
    }
}
