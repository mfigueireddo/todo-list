@page "/tarefas"
@attribute [Authorize]
@using System.Security.Claims
@inject TaskApiClient TaskApi
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

@*
    Página de listagem de tarefas. 
    
    Mostra um accordion por tarefa:
    - No cabeçalho ficam título, data e o checkbox de concluída; 
    - Ao expandir, aparecem descrição, responsável e a dificuldade como tag colorida. 
    
    Há filtro por nome e os botões disponíveis variam conforme o papel: 
    - Excluir só para admin; 
    - Editar e o checkbox só para o admin ou o responsável;
    - "Atribuir-me" quando a tarefa não tem responsável.
*@

<PageTitle>Lista de Tarefas</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Lista de Tarefas</h1>
    <a class="btn btn-primary" href="tarefas/nova">Adicionar Nova Tarefa</a>
</div>

<div class="input-group mb-3">
    <input type="text" class="form-control" placeholder="Pesquisar pelo nome da tarefa..."
           @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
    <button class="btn btn-outline-secondary" type="button" @onclick="ApplyFilterAsync">Pesquisar</button>
</div>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

@if (_isLoading)
{
    <p class="text-muted">Carregando tarefas...</p>
}
else if (_tasks.Count == 0)
{
    <p class="text-muted">Nenhuma tarefa encontrada.</p>
}
else
{
    <div class="accordion" id="tasksAccordion">
        @foreach (TaskDto task in _tasks)
        {
            string bodyId = $"task-body-{task.Id}";

            <div class="accordion-item">
                <div class="accordion-header d-flex align-items-center gap-2 pe-2">
                    <input class="form-check-input ms-3 mt-0" type="checkbox" checked="@task.IsCompleted"
                           disabled="@(!CanEdit(task))" @onchange="() => ToggleCompletedAsync(task)" title="Marcar como concluída" />

                    <button class="accordion-button collapsed flex-grow-1" type="button"
                            data-bs-toggle="collapse" data-bs-target="@($"#{bodyId}")">
                        <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                            <strong>@task.Title</strong>
                            <span class="ms-2 text-muted">@task.DueDate.ToString("dd/MM/yyyy")</span>
                        </span>
                    </button>

                    @if (CanAssignSelf(task))
                    {
                        <button class="btn btn-sm btn-outline-primary" type="button"
                                @onclick="() => AssignSelfAsync(task)">Atribuir-me</button>
                    }
                    @if (CanEdit(task))
                    {
                        <button class="btn btn-sm btn-outline-secondary" type="button"
                                @onclick="() => EditTask(task.Id)">Editar</button>
                    }
                    @if (CanDelete(task))
                    {
                        <button class="btn btn-sm btn-outline-danger" type="button"
                                @onclick="() => DeleteTaskAsync(task)">Excluir</button>
                    }
                </div>

                <div id="@bodyId" class="accordion-collapse collapse" data-bs-parent="#tasksAccordion">
                    <div class="accordion-body">
                        <p><strong>Descrição:</strong> @(string.IsNullOrWhiteSpace(task.Description) ? "—" : task.Description)</p>
                        <p class="mb-1">
                            <strong>Dificuldade:</strong>
                            <span class="badge @DifficultyDisplay.GetBadgeCssClass(task.Difficulty)">
                                @DifficultyDisplay.GetLabel(task.Difficulty)
                            </span>
                        </p>
                        <p class="mb-1"><strong>Responsável:</strong> @ResponsibleLabel(task)</p>
                        <p class="mb-0"><strong>Concluída:</strong> @(task.IsCompleted ? "Sim" : "Não")</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    /// <summary>Estado de autenticação atual, fornecido pelo <CascadingAuthenticationState> (App.razor).</summary>
    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    /// <summary>Tarefas atualmente exibidas (já filtradas pelo servidor quando há busca).</summary>
    private List<TaskDto> _tasks = new();

    /// <summary>Texto do filtro por nome, vinculado ao campo de busca.</summary>
    private string _searchTerm = string.Empty;

    /// <summary>Indica que a listagem está sendo carregada (mostra estado de "Carregando").</summary>
    private bool _isLoading = true;

    /// <summary>Mensagem de erro a exibir quando uma operação falha; nula quando não há erro.</summary>
    private string? _errorMessage;

    /// <summary>Identificador do usuário autenticado, usado para decidir o que ele pode editar.</summary>
    private Guid? _currentUserId;

    /// <summary>Indica se o usuário autenticado é admin (pode excluir e editar qualquer tarefa).</summary>
    private bool _isAdmin;

    /// <summary>
    ///
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Resolve a identidade do usuário (id e papel) a partir do estado de autenticação.
    /// </para>
    ///
    /// <para>
    /// Carrega a lista completa de tarefas.
    /// </para>
    ///
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        AuthenticationState authState = await this.AuthenticationStateTask;
        ClaimsPrincipal user = authState.User;

        this._isAdmin = user.IsInRole(AppRoles.Admin);

        string? subject = user.FindFirst(JwtClaimNames.Subject)?.Value;
        this._currentUserId = Guid.TryParse(subject, out Guid userId) ? userId : null;

        await this.LoadTasksAsync();
    }

    /// <summary>
    ///
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Busca as tarefas na API aplicando o filtro atual e atualiza o estado da página.
    /// </para>
    ///
    /// <para>
    /// Captura falhas de comunicação para exibi-las ao usuário.
    /// </para>
    ///
    /// </summary>
    ///
    /// <remarks>
    ///
    /// === <b>Assertivas de Saída</b> ===
    ///
    /// <para>
    /// Ao término, <c>_isLoading</c> é falso e <c>_tasks</c> reflete o resultado da API
    /// (ou ficou inalterado, com <c>_errorMessage</c> preenchido, em caso de falha).
    /// </para>
    ///
    /// </remarks>
    private async Task LoadTasksAsync()
    {
        this._isLoading = true;
        this._errorMessage = null;

        try
        {
            IReadOnlyList<TaskDto> result = await this.TaskApi.GetAllAsync(this._searchTerm);
            this._tasks = result.ToList();
        }
        catch (HttpRequestException exception)
        {
            this._errorMessage = $"Não foi possível carregar as tarefas: {exception.Message}";
        }
        finally
        {
            this._isLoading = false;
        }
    }

    /// <summary>Reaplica o filtro a partir do texto digitado, recarregando a lista pela API.</summary>
    private async Task ApplyFilterAsync()
    {
        await this.LoadTasksAsync();
    }

    /// <summary>Dispara a busca quando o usuário pressiona Enter no campo de filtro.</summary>
    ///
    /// <param name="args">Dados do evento de teclado; usado para identificar a tecla Enter.</param>
    private async Task OnSearchKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await this.LoadTasksAsync();
        }
    }

    /// <summary>
    /// 
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Alterna o estado de conclusão de uma tarefa e persiste a mudança via PUT na API.
    /// </para>
    ///
    /// <para>
    /// Recarrega a lista para refletir o novo estado.
    /// </para>
    ///
    /// </summary>
    ///
    /// <param name="task">Tarefa cujo checkbox foi alterado.</param>
    ///
    /// <remarks>
    ///
    /// === <b>Restrições</b> ===
    ///
    /// <para>
    /// Reutiliza o endpoint de edição (PUT /tasks/{id}); 
    /// só está habilitado para quem pode editar (admin ou responsável).
    /// </para>
    ///
    /// </remarks>
    private async Task ToggleCompletedAsync(TaskDto task)
    {
        UpdateTaskRequest request = new()
        {
            Title = task.Title,
            Description = task.Description,
            DueDate = task.DueDate,
            Difficulty = task.Difficulty,
            ResponsibleUserId = task.ResponsibleUserId,
            IsCompleted = !task.IsCompleted
        };

        string? error = await this.TaskApi.UpdateAsync(task.Id, request);

        if (error is not null)
        {
            this._errorMessage = error;
            return;
        }

        await this.LoadTasksAsync();
    }

    /// <summary>Autoatribui o usuário autenticado como responsável da tarefa e recarrega a lista.</summary>
    ///
    /// <param name="task">Tarefa a ser autoatribuída.</param>
    private async Task AssignSelfAsync(TaskDto task)
    {
        string? error = await this.TaskApi.AssignSelfAsync(task.Id);

        if (error is not null)
        {
            this._errorMessage = error;
            return;
        }

        await this.LoadTasksAsync();
    }

    /// <summary>Navega para a página de edição da tarefa selecionada.</summary>
    ///
    /// <param name="id">Identificador da tarefa a editar.</param>
    private void EditTask(Guid id)
    {
        this.Navigation.NavigateTo($"tarefas/{id}/editar");
    }

    /// <summary>
    ///
    /// === <b>Descrição</b> ===
    ///
    /// <para>
    /// Pede confirmação ao usuário e, se confirmada, exclui a tarefa via DELETE na API.
    /// </para>
    ///
    /// <para>
    /// Recarrega a lista após a exclusão.
    /// </para>
    ///
    /// </summary>
    ///
    /// <param name="task">Tarefa a ser excluída.</param>
    private async Task DeleteTaskAsync(TaskDto task)
    {
        bool confirmed = await this.JsRuntime.InvokeAsync<bool>("confirm", $"Excluir a tarefa \"{task.Title}\"?");

        if (!confirmed)
        {
            return;
        }

        try
        {
            await this.TaskApi.DeleteAsync(task.Id);
            await this.LoadTasksAsync();
        }
        catch (HttpRequestException exception)
        {
            this._errorMessage = $"Não foi possível excluir a tarefa: {exception.Message}";
        }
    }

    /// <summary>Indica se o usuário atual pode editar a tarefa (admin ou responsável atual).</summary>
    ///
    /// <param name="task">Tarefa avaliada.</param>
    ///
    /// <returns>Retorna <c>true</c> quando o usuário é admin ou o responsável da tarefa.</returns>
    private bool CanEdit(TaskDto task)
    {
        return this._isAdmin || (this._currentUserId is not null && task.ResponsibleUserId == this._currentUserId);
    }

    /// <summary>Indica se o usuário atual pode excluir a tarefa (apenas admin).</summary>
    ///
    /// <param name="task">Tarefa avaliada.</param>
    ///
    /// <returns>Retorna <c>true</c> quando o usuário é admin.</returns>
    private bool CanDelete(TaskDto task)
    {
        return this._isAdmin;
    }

    /// <summary>Indica se o usuário pode se autoatribuir como responsável (a tarefa não tem responsável).</summary>
    ///
    /// <param name="task">Tarefa avaliada.</param>
    ///
    /// <returns>Retorna <c>true</c> quando a tarefa está sem responsável.</returns>
    private bool CanAssignSelf(TaskDto task)
    {
        return task.ResponsibleUserId is null;
    }

    /// <summary>Produz o rótulo do responsável para exibição (nome do usuário ou "Não atribuído").</summary>
    ///
    /// <param name="task">Tarefa cujo responsável será rotulado.</param>
    ///
    /// <returns>
    /// Retorna o nome do responsável quando há um.
    /// Retorna "Não atribuído" quando a tarefa não tem responsável.
    /// </returns>
    private static string ResponsibleLabel(TaskDto task)
    {
        return string.IsNullOrWhiteSpace(task.ResponsibleUserName) ? "Não atribuído" : task.ResponsibleUserName;
    }
}
