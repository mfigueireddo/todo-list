@page "/"
@attribute [Authorize]
@inject NavigationManager Navigation

@*
    Página inicial. 
    Não tem conteúdo próprio: apenas redireciona o usuário para a lista de tarefas (/tarefas).
    Protegida por [Authorize]: um usuário deslogado é redirecionado ao login (via <RedirectToLogin>).
*@

@code {
    /// <summary>
    /// Ao inicializar a página, redireciona imediatamente para a lista de tarefas (o usuário já está autenticado aqui).
    /// </summary>
    protected override void OnInitialized()
    {
        this.Navigation.NavigateTo("tarefas");
    }
}
